{
  "title": "Pool Tracker",
  "config": {
    "step": {
      "user": {
        "title": "Add pool",
        "description": "Create a local manual pool maintenance log.",
        "data": {
          "name": "Pool name",
          "volume": "Volume",
          "volume_unit": "Volume unit",
          "pool_type": "Pool type",
          "surface_type": "Surface type",
          "sanitizer_type": "Sanitizer type",
          "default_testing_method": "Default testing method",
          "typically_covered": "Typically covered",
          "weather_entity_id": "Weather entity",
          "cover_entity_id": "Cover entity"
        }
      }
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Pool profile",
        "description": "Update pool attributes used by Pool Tracker records.",
        "data": {
          "name": "Pool name",
          "volume": "Volume",
          "volume_unit": "Volume unit",
          "pool_type": "Pool type",
          "surface_type": "Surface type",
          "sanitizer_type": "Sanitizer type",
          "default_testing_method": "Default testing method",
          "typically_covered": "Typically covered",
          "weather_entity_id": "Weather entity",
          "cover_entity_id": "Cover entity"
        }
      }
    }
  },
  "services": {
    "log_water_test": {
      "name": "Log water test",
      "description": "Append a manual water-test record.",
      "fields": {
        "pool_id": {
          "name": "Pool ID",
          "description": "Pool identifier. Leave blank for the only configured pool."
        },
        "event_timestamp": {
          "name": "Event timestamp",
          "description": "When the test happened. Leave blank to use now."
        },
        "source": {
          "name": "Source",
          "description": "Optional caller label such as dashboard, service, or agent."
        },
        "free_chlorine": {
          "name": "Free chlorine",
          "description": "Free chlorine reading in ppm."
        },
        "ph": {
          "name": "pH",
          "description": "pH reading."
        },
        "total_alkalinity": {
          "name": "Total alkalinity",
          "description": "Total alkalinity reading in ppm."
        },
        "cya": {
          "name": "CYA/stabilizer",
          "description": "CYA/stabilizer reading in ppm."
        },
        "water_clarity": {
          "name": "Water clarity",
          "description": "Manual clarity note such as clear, cloudy, or green."
        },
        "testing_method": {
          "name": "Testing method",
          "description": "Override the pool's default testing method for this water test."
        },
        "notes": {
          "name": "Notes",
          "description": "Optional free-form note."
        }
      }
    },
    "log_chemical_addition": {
      "name": "Log chemical addition",
      "description": "Append a manual chemical-addition record.",
      "fields": {
        "pool_id": {
          "name": "Pool ID",
          "description": "Pool identifier. Leave blank for the only configured pool."
        },
        "event_timestamp": {
          "name": "Event timestamp",
          "description": "When the addition happened. Leave blank to use now."
        },
        "source": {
          "name": "Source",
          "description": "Optional caller label such as dashboard, service, or agent."
        },
        "chemical": {
          "name": "Chemical",
          "description": "Human-entered chemical name or type."
        },
        "amount": {
          "name": "Amount",
          "description": "Human-entered amount."
        },
        "unit": {
          "name": "Unit",
          "description": "Unit for the amount."
        },
        "notes": {
          "name": "Notes",
          "description": "Optional free-form note."
        }
      }
    },
    "get_prediction": {
      "name": "Get prediction",
      "description": "Return the full prediction series, actuals, and model inputs for a prediction sensor."
    }
  },
  "entity": {
    "event": {
      "water_test": {
        "name": "Water test"
      },
      "chemical_addition": {
        "name": "Chemical addition"
      }
    },
    "sensor": {
      "free_chlorine": {
        "name": "Free chlorine"
      },
      "ph": {
        "name": "pH"
      },
      "total_alkalinity": {
        "name": "Total alkalinity"
      },
      "cya": {
        "name": "CYA/stabilizer"
      },
      "water_clarity": {
        "name": "Water clarity",
        "state": {
          "clear": "Clear",
          "hazy": "Hazy",
          "cloudy": "Cloudy",
          "green": "Green",
          "other": "Other"
        }
      },
      "free_chlorine_predicted": {
        "name": "Free chlorine (Predicted)"
      },
      "ph_predicted": {
        "name": "pH (Predicted)"
      },
      "total_alkalinity_predicted": {
        "name": "Total alkalinity (Predicted)"
      },
      "cya_predicted": {
        "name": "CYA/stabilizer (Predicted)"
      }
    }
  }
}
